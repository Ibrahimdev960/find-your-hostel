# ─────────────────────────────────────────────────────────────────────────────
# Find Your Hostel — environment template (committed). Copy per app to .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (find these in your Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — used by route handlers / webhooks. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
